{
	"name": "@w-lfpup/hyperevents",
	"description": "A hypertext extension for the browser",
	"type": "module",
	"main": "dist/mod.js",
	"author": "Taylor Vann",
	"version": "0.2.1",
	"license": "BSD-3-Clause",
	"scripts": {
		"prepare": "npm run build",
		"build": "npm run build:src && npm run build:examples",
		"build:src": "npx tsc --project ./src",
		"build:examples": "npx tsc --project ./examples",
		"format": "npx prettier ./ --write"
	},
	"devDependencies": {
		"@w-lfpup/jackrabbit": "^0.3.3",
		"prettier": "^3.8.3",
		"typescript": "^6.0.3"
	}
}
